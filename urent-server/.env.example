# Server
PORT=5003
NODE_ENV=production

# Database
MONGO_URI=
# MONGO_URI_FALLBACK=
# DNS_SERVERS=8.8.8.8,1.1.1.1

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=1d

# CORS — comma-separated frontend URLs (include Vercel preview/production URLs)
CLIENT_URLS=https://your-app.vercel.app,https://your-app-git-dev-team.vercel.app

# Email (OTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
OTP_EXPIRES_MINUTES=10
RESET_TOKEN_EXPIRES_MINUTES=15

# Cloudinary (avatar upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_API_KEY=
