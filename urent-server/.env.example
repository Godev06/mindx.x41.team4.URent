# Server
PORT=your_port

# Database
MONGO_URI=your_mongodb_uri
MONGO_URI_FALLBACK=your_fallback_mongodb_uri
DNS_SERVERS=your_dns_servers

# Auth
JWT_SECRET=your_secret
JWT_EXPIRES_IN=your_jwt_expires_in

# CORS
CLIENT_URL=your_client_url
CLIENT_URLS=your_client_urls

# Email (OTP)
SMTP_HOST=your_smtp_host
SMTP_PORT=your_smtp_port
SMTP_SECURE=your_smtp_secure
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM=your_email_from
OTP_EXPIRES_MINUTES=your_otp_expires_minutes
RESET_TOKEN_EXPIRES_MINUTES=your_reset_token_expires_minutes

# Cloudinary (avatar upload)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Firebase Admin
FIREBASE_SERVICE_ACCOUNT_PATH=your_firebase_service_account_path
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_API_KEY=your_firebase_api_key
