{
  "name": "be",
  "version": "1.0.0",
  "main": "build/server.js",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:node": "tsx watch src/server.ts",
    "dev:once": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "check": "npm run typecheck",
    "build": "tsc",
    "build:vercel": "npm run typecheck && npm run build",
    "vercel-build": "npm run build:vercel",
    "start": "node build/src/server.js",
    "serve": "node build/src/server.js",
    "start:prod": "npm run build && npm run start",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "db:sync-reviews": "tsx scripts/sync-reviews.ts",
    "unify:categories": "tsx scripts/unify-categories.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.10.0",
    "mongoose": "^8.18.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.0",
    "@types/nodemailer": "^8.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@vercel/node": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
