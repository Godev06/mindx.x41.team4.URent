{
  "name": "urent-server",
  "main": "src/worker.ts",
  "workers_dev": true,
  "preview_urls": false,
  "compatibility_date": "2025-09-25",
  "compatibility_flags": [
    "nodejs_compat",
    "enable_nodejs_http_server_modules"
  ],
  "observability": {
    "enabled": true
  },
  "alias": {
    "@firebase/database-compat/standalone": "./src/mock-firebase.js",
    "swagger-ui-express": "./src/mock-swagger.js",
    "swagger-jsdoc": "./src/mock-swagger-jsdoc.js",
    "whatwg-url": "./src/mock-whatwg-url.js"
  }
}